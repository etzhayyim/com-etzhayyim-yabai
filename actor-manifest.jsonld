{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:yabai.etzhayyim.com",
  "actors": [
    {
      "description": "IP address risk scoring and WAF integration",
      "displayName": "IP Risk Analyzer",
      "path": "ip:risk"
    },
    {
      "description": "Defensive Tor exit and case-bound torrent evidence correlation; never de-anonymizes private persons",
      "displayName": "Tor/Torrent CTI Correlator",
      "path": "cti:tor-torrent"
    },
    {
      "description": "Person entity AML/sanctions screening",
      "displayName": "Person Risk Analyzer",
      "path": "person:risk"
    },
    {
      "description": "Organization entity risk assessment",
      "displayName": "Org Risk Analyzer",
      "path": "org:risk"
    }
  ],
  "capabilities": [
    "graph.query",
    "graph.write",
    "graph.vectorSearch",
    "agent.chat",
    "agent.invoke",
    "browser.fetch",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"
  ],
  "convoSystemPrompt": "You are the Yabai agent — a risk intelligence platform. You score entities for AML/sanctions/anti-social risk, analyze IP addresses for threats, manage 6 layers of CTI (Network, Vuln, Threat, Exchange, Infra, Access Audit), correlate public Tor-exit indicators and case-bound torrent evidence, and integrate with CF WAF. Evidence categories: SanctionHit(×20), CriminalEvidence(×15), AntiSocialAssociation(×12), AMLPattern(×10), FraudSignal(×8). Alert thresholds: Monitor≥70, Challenge≥85, Deny≥95. Never use Tor/torrent evidence to de-anonymize private persons or etzhayyim adherents; keep it to defensive routing, abuse reporting, and case evidence preservation.",
  "description": "AML/sanctions/anti-social forces risk scoring, IP access filtering, defensive Tor/torrent CTI, 6-layer CTI (Network/Vuln/Threat/Exchange/Infra/Access Audit), CF WAF integration.",
  "displayName": "Yabai — Risk Intelligence (AML/CTI)",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "governance": {
    "classification": "restricted",
    "complianceFrameworks": [
      "AML",
      "NIST CSF 2.0",
      "STIX 2.1"
    ],
    "raci": "responsible"
  },
  "heartbeatRequired": true,
  "name": "yabai",
  "nanoid": "y8b41k0x",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "id": "entity",
          "fn": "graph.query",
          "args": {
            "sql": "SELECT e.entity_id AS \"entityId\", e.entity_type AS \"entityType\", array_agg(ev.category) AS categories, count(ev.vertex_id) AS \"evidenceCount\" FROM vertex_yabai_entity e LEFT JOIN vertex_yabai_evidence ev ON ev.entity_id = e.entity_id WHERE e.entity_id = $entityId GROUP BY e.entity_id, e.entity_type LIMIT 1",
            "params": {
              "entityId": "$input.record.entityId"
            }
          }
        },
        {
          "id": "score",
          "fn": "agent.chat",
          "args": {
            "message": "Score this entity for risk.\n\nNew evidence: $input.record\nEntity: $entity.rows\n\nWeights: SanctionHit=20, CriminalEvidence=15, AntiSocialAssociation=12, AMLPattern=10, FraudSignal=8, IntelExtraction=3.\nRecency decay: ≤30d→1.0, ≤1y→0.9, ≤3y→0.7, >3y→0.5.\nAlert thresholds: Monitor≥70, Challenge≥85, Deny≥95.\n\nReturn JSON: {riskScore, level: monitor|challenge|deny|clean, breakdown}"
          }
        },
        {
          "id": "writeRisk",
          "fn": "graph.write",
          "args": {
            "sql": "INSERT INTO vertex_yabai_risk (vertex_id, rkey, repo, owner_did, entity_id, level, scored_at, created_date, sensitivity_ord, actor_id) VALUES (concat('at://', $did, '/com.etzhayyim.apps.yabai.risk/', $entityId, ':', $ts), $entityId, $did, $did, $entityId, $level, $ts, CURRENT_DATE, 300, 't1:yabai')",
            "params": {
              "entityId": "$input.record.entityId",
              "level": "$score.text",
              "ts": "$input.record.occurredAt"
            }
          }
        },
        {
          "id": "announce",
          "fn": "derive:social",
          "depends_on": [
            "score"
          ],
          "args": {
            "template": "Risk assessment: $score.text"
          }
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.yabai.evidence"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "id": "ipIngest",
          "fn": "graph.write",
          "args": {
            "sql": "INSERT INTO vertex_yabai_entity (vertex_id, rkey, repo, owner_did, entity_id, entity_type, name, value, source, created_at, created_date, sensitivity_ord, actor_id) VALUES (concat('at://', $did, '/com.etzhayyim.apps.yabai.entity/ip-', $ipSlug), concat('ip-', $ipSlug), $did, $did, concat('ip-', $ipSlug), 'IPAddress', $ip, $ip, 'ipaddress.follow', NOW()::VARCHAR, CURRENT_DATE, 300, 't1:yabai')",
            "params": {
              "ip": "$input.record.address",
              "ipSlug": "$input.rkey"
            }
          }
        },
        {
          "id": "ipScore",
          "fn": "agent.chat",
          "args": {
            "message": "Score this IP for risk.\n\nIP data: $input.record\n\nIP weights: KnownBotnet=15, BruteForce=12, TorExitNode=10, RateAbuse=8, GeoAnomaly=5, VPNDatacenter=3.\nReturn JSON: {ipRiskScore, indicators, level}"
          }
        },
        {
          "id": "writeIpRisk",
          "fn": "graph.write",
          "args": {
            "sql": "INSERT INTO vertex_yabai_risk (vertex_id, rkey, repo, owner_did, entity_id, entity_type, level, scored_at, created_date, sensitivity_ord, actor_id) VALUES (concat('at://', $did, '/com.etzhayyim.apps.yabai.risk/ip-', $ipSlug, ':', NOW()::VARCHAR), concat('ip-', $ipSlug), $did, $did, concat('ip-', $ipSlug), 'IPAddress', $level, NOW()::VARCHAR, CURRENT_DATE, 300, 't1:yabai')",
            "params": {
              "ipSlug": "$input.rkey",
              "level": "$ipScore.text"
            }
          }
        },
        {
          "id": "announce",
          "fn": "derive:social",
          "depends_on": [
            "ipScore"
          ],
          "args": {
            "template": "New data added: $ipScore.text"
          }
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.ipaddress.ipAddress",
          "com.etzhayyim.apps.ipaddress.ipAnalysis"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "id": "highRisk",
          "fn": "graph.query",
          "args": {
            "sql": "SELECT entity_id AS \"entityId\", risk_score AS score, level FROM vertex_yabai_risk WHERE risk_score >= 85 ORDER BY risk_score DESC LIMIT 20"
          }
        },
        {
          "id": "alerts",
          "fn": "graph.query",
          "depends_on": [],
          "args": {
            "sql": "SELECT count(*) AS \"openAlerts\" FROM vertex_yabai_alert WHERE status = 'open'"
          }
        },
        {
          "id": "summary",
          "fn": "agent.chat",
          "depends_on": [
            "highRisk",
            "alerts"
          ],
          "args": {
            "message": "Yabai risk intelligence briefing.\n\nHigh-risk entities (score≥85):\n$highRisk.rows\n\nOpen alerts: $alerts.rows\n\nSummarize threat landscape and recommend priority actions."
          }
        },
        {
          "id": "announce",
          "fn": "derive:social",
          "args": {
            "template": "Yabai threat briefing: $summary.text"
          }
        }
      ],
      "trigger": {
        "cron": "0 0/4 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "id": "coverageNodes",
          "fn": "graph.query",
          "args": {
            "sql": "SELECT (SELECT count(*) FROM vertex_yabai_entity WHERE repo = $did) + (SELECT count(*) FROM vertex_yabai_evidence WHERE repo = $did) + (SELECT count(*) FROM vertex_yabai_risk WHERE repo = $did) AS \"nodeCount\""
          }
        },
        {
          "id": "coverageCollections",
          "fn": "graph.query",
          "depends_on": [],
          "args": {
            "sql": "SELECT collection, cnt FROM (SELECT 'com.etzhayyim.apps.yabai.entity' AS collection, count(*) AS cnt FROM vertex_yabai_entity WHERE repo = $did UNION ALL SELECT 'com.etzhayyim.apps.yabai.evidence', count(*) FROM vertex_yabai_evidence WHERE repo = $did UNION ALL SELECT 'com.etzhayyim.apps.yabai.risk', count(*) FROM vertex_yabai_risk WHERE repo = $did UNION ALL SELECT 'com.etzhayyim.apps.yabai.alert', count(*) FROM vertex_yabai_alert WHERE repo = $did UNION ALL SELECT 'com.etzhayyim.apps.yabai.flag', count(*) FROM vertex_yabai_flag WHERE repo = $did) t WHERE cnt > 0 ORDER BY cnt DESC LIMIT 10"
          }
        },
        {
          "id": "coverageSnapshot",
          "fn": "graph.write",
          "depends_on": [
            "coverageNodes"
          ],
          "args": {
            "sql": "INSERT INTO vertex_actor_coverage (vertex_id, rkey, repo, owner_did, did, collection, status, \"actorDid\", \"actorName\", nanoid, bucket, \"nodeCount\", \"latestTs\", created_date, sensitivity_ord) VALUES (concat('at://', $did, '/com.etzhayyim.apps.yabai.coverageSnapshot/', NOW()::VARCHAR), NOW()::VARCHAR, $did, $did, $did, 'com.etzhayyim.apps.yabai.coverageSnapshot', 'active', $did, 'yabai', 'y8b41k0x', '6h', $nodeCount, NOW()::VARCHAR, CURRENT_DATE, 300)",
            "params": {
              "nodeCount": "$coverageNodes.rows[0].nodeCount"
            }
          }
        },
        {
          "id": "compose",
          "fn": "agent.chat",
          "depends_on": [
            "coverageSnapshot"
          ],
          "args": {
            "message": "You are Yabai — Risk Intelligence (AML/CTI). Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"
          }
        },
        {
          "id": "announce",
          "fn": "derive:social",
          "depends_on": [
            "compose"
          ],
          "args": {
            "template": "$compose.text"
          }
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "id": "coverageStats",
          "fn": "graph.query",
          "args": {
            "sql": "SELECT \"nodeCount\", \"latestTs\", \"topCollections\", _seq AS \"snapshotSeq\" FROM vertex_actor_coverage WHERE \"actorDid\" = $did ORDER BY _seq DESC LIMIT 1"
          }
        },
        {
          "id": "coverageHealth",
          "fn": "graph.query",
          "depends_on": [],
          "args": {
            "sql": "SELECT \"nodeCount\" AS \"totalNodes\" FROM vertex_actor_coverage WHERE \"actorDid\" = $did ORDER BY _seq DESC LIMIT 1"
          }
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.yabai.coverage.get",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "risk-assessment",
      "network-intel",
      "vuln-intel",
      "threat-intel",
      "exchange-intel",
      "infra-intel",
      "access-audit"
    ],
    "description": "AML/sanctions/anti-social risk scoring + 6-layer CTI (WHOIS/DNS/ASN/GeoIP, CVE/MITRE, TLS/Malware/IOC/Phishing, STIX/BGP/Abuse, Hosting/IP History, Access Audit). CF WAF integration.",
    "displayName": "Yabai — Risk Intelligence (AML/CTI)",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.yabai.entity",
        "com.etzhayyim.apps.yabai.evidence",
        "com.etzhayyim.apps.ipaddress.ipAddress",
        "com.etzhayyim.apps.ipaddress.ipAnalysis"
      ]
    }
  },
  "uiType": "appview"
}
